<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PersonalDataActivity"
    android:background="@drawable/bg_1">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginTop="82dp"
        android:src="@drawable/ic_callibri_logo_1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/edit_birthday_reg"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"
        android:background="@drawable/edit_text_background"
        android:fontFamily="@font/montserrat_regular"
        android:hint="День рождения"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:textColor="@color/white"
        android:textColorHint="@color/white"
        android:textSize="19sp"

        android:layout_marginTop="110dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView7" />

    <EditText
        android:id="@+id/edit_height_reg"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"
        android:background="@drawable/edit_text_background"
        android:fontFamily="@font/montserrat_regular"
        android:hint="Рост"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:textColor="@color/white"
        android:textColorHint="@color/white"
        android:textSize="19sp"

        android:layout_marginTop="19dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_birthday_reg" />

    <EditText
        android:id="@+id/edit_weight_reg"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"
        android:background="@drawable/edit_text_background"
        android:fontFamily="@font/montserrat_regular"
        android:hint="Вес"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:textColor="@color/white"
        android:textColorHint="@color/white"
        android:textSize="19sp"

        android:layout_marginTop="19dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_height_reg" />

    <RadioGroup
        android:id="@+id/radio_group_sex"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_weight_reg"
        android:layout_marginTop="19dp">

        <RadioButton
            android:id="@+id/radio_group_sex_male"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_regular"
            android:text="Мужчина"
            android:textColor="@color/white"
            android:textSize="19sp"
            android:layout_marginHorizontal="10dp"/>

        <RadioButton
            android:id="@+id/radio_group_sex_female"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_regular"
            android:text="Женщина"
            android:textColor="@color/white"
            android:textSize="19sp"
            android:layout_marginHorizontal="10dp"/>

    </RadioGroup>

    <Button
        android:id="@+id/button_register_2"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"

        android:backgroundTint="@color/button_color_1"
        android:fontFamily="@font/montserrat_regular"
        android:text="Зарегистрироваться"
        android:textColor="#BF000000"

        android:textSize="19sp"
        app:cornerRadius="100dp"
        android:layout_marginTop="19dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/radio_group_sex" />

</androidx.constraintlayout.widget.ConstraintLayout>