<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/autorization"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_1">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="82dp"
        android:layout_marginEnd="51dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_callibri_logo_1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/autorization_error_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="20dp"

        android:text="Неверный электорнный адрес или пароль.\nПроверьте правильность введенных данных"
        android:textColor="#A00202"
        android:textSize="15sp"
        android:visibility="gone"
        android:fontFamily="@font/montserrat_regular"
        app:layout_constraintBottom_toTopOf="@+id/edit_email"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <EditText
        android:id="@+id/edit_email"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="56dp"
        android:layout_marginTop="126dp"
        android:layout_marginEnd="56dp"
        android:background="@drawable/edit_text_background"
        android:hint="Эл. адрес"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:textColorHint="#7AFFFFFF"
        android:textSize="19sp"
        android:fontFamily="@font/montserrat_regular"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <EditText
        android:id="@+id/edit_pass"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"
        android:background="@drawable/edit_text_background"
        android:hint="Пароль"
        android:textColorHint="#7AFFFFFF"
        android:textSize="19sp"
        android:fontFamily="@font/montserrat_regular"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_email" />


    <Button
        android:id="@+id/btn_log_in"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="33dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"
        android:backgroundTint="@color/button_color_1"
        android:gravity="center"
        android:text="Войти"
        android:textColor="#BF000000"
        android:textSize="19sp"
        android:fontFamily="@font/montserrat_regular"
        app:cornerRadius="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_pass" />

    <Button
        android:id="@+id/btn_go_to_reg"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="17dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"

        android:backgroundTint="@color/button_color_2"
        android:gravity="center"
        android:text="Регистрация"
        android:textColor="#BF000000"
        android:textSize="19sp"
        android:fontFamily="@font/montserrat_regular"
        app:cornerRadius="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_log_in" />

    <include layout="@layout/welcome_screen"
        android:visibility="gone"/>



</androidx.constraintlayout.widget.ConstraintLayout>