<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NewSessionActivity"
    android:background="@drawable/bg_2">

    <LinearLayout

        android:id="@+id/linearLayout8"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="87dp"

            android:fontFamily="@font/montserrat_regular"
            android:gravity="center"
            android:text="Новый сеанс"
            android:textColor="@color/black"
            android:textSize="26dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#BDCDFF" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@android:color/transparent"

        android:src="@drawable/menu"
        app:layout_constraintBottom_toBottomOf="@+id/linearLayout8"
        app:layout_constraintStart_toStartOf="@+id/linearLayout8"
        android:layout_marginStart="14dp"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/linearLayout9"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/history_block_bg"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:layout_marginHorizontal="20dp">

            <TextView
                android:id="@+id/text_pulse_tab"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/tab_unselected"
                android:gravity="center"
                android:text="Пульс"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:fontFamily="@font/montserrat_regular" />

            <TextView
                android:id="@+id/text_stress_tab"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/tab_unselected"
                android:gravity="center"
                android:text="Стресс"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:fontFamily="@font/montserrat_regular" />
        </LinearLayout>

        <TextView
            android:id="@+id/textViewHR"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginHorizontal="35dp"
            android:layout_marginTop="25dp"
            android:fontFamily="@font/montserrat_regular"
            android:text="___ уд/мин"
            android:textColor="@color/black"
            android:textSize="15sp" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartHR"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_session_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#578FFF"
        android:textColor="@color/white"
        android:text="Завершить"
        android:fontFamily="@font/montserrat_regular"
        android:layout_margin="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout9" />


    <include

        android:id="@+id/menu_layout"
        layout="@layout/side_menu"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>